{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components": ["src/libs/components/index.ts"],
      "@constants": ["src/libs/constants/index.ts"],
      "@enums": ["src/libs/enums/index.ts"],
      "@hooks": ["src/libs/hooks/index.ts"],
      "@models": ["src/libs/models/index.ts"],
      "@providers": ["src/libs/providers/index.ts"],
      "@utils": ["src/libs/utils/index.ts"],
      "@assets/icons": ["src/libs/assets/icons/index.ts"],
      "@validations": ["src/libs/validations/index.ts"],
      "@pages/*": ["src/pages/*"],
    },
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Other */
    "types": ["vite-plugin-svgr/client"]
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
